{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"isolatedModules": true,
		"noEmit": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"jsx": "react-jsx",
		"paths": {
			"@/*": ["./apps/web/src/*"]
		}
	},
	"include": [
		"apps/**/*.ts",
		"apps/**/*.tsx",
		"packages/**/*.ts",
		"packages/**/*.tsx",
		"services/**/*.ts",
		"services/**/*.tsx",
		"scripts/**/*.ts",
		"eslint-rules/**/*.ts",
		"eslint-rules/**/*.mjs"
	],
	"exclude": [
		"node_modules",
		"**/dist",
		"**/.next",
		"**/.turbo",
		"**/*.test.ts",
		"**/*.test.tsx",
		"**/*.spec.ts",
		"**/*.spec.tsx",
		"**/__tests__/**"
	]
}
