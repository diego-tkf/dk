# dk — environment variables
# Copy to .env.local (gitignored) and fill in.

# ── Database (Postgres) ─────────────────────────────────────────────────────
# Local dev (matches infra/docker-compose.yml defaults):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dk
# Production: use the Supabase project pooled connection string.

# ── Redis (BullMQ) ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Supabase ────────────────────────────────────────────────────────────────
# From Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side only — NEVER ship this to the client. Used by background
# workers and admin operations that need to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Microsoft Entra (later) ─────────────────────────────────────────────────
# Configured in the Supabase Auth dashboard once the Azure app registration
# is in place. Not used by the app directly — Supabase handles the OIDC flow.
# AZURE_AD_CLIENT_ID=
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_SECRET=

# ── AI providers (used by @dk/llm and @dk/image-gen wrappers) ──────────────
ANTHROPIC_API_KEY=sk-ant-…
OPENAI_API_KEY=sk-…

# ── Observability (optional in dev) ────────────────────────────────────────
# SENTRY_DSN=
